# journal :: .env.example
#
# Copy this file to .env at the project root and fill in your provider key.
# .env is git-ignored. The feedback server (journal/scripts/start.sh) picks
# it up automatically.

# --- Provider selection ----------------------------------------------------
# Default: gemini (free-tier path).
# Switch to openai or anthropic if you have one of those keys instead.
LLM_PROVIDER=gemini

# Model per-provider. Free-tier note:
#   gemini-2.5-pro may return `limit: 0` on free tier (paid only).
#   gemini-2.5-flash is free at the time of writing.
#   Verify: https://ai.google.dev/gemini-api/docs/rate-limits
MODEL_ID=gemini-2.5-flash

# --- Gemini ---------------------------------------------------------------
# Get a key (free): https://ai.google.dev/gemini-api
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
# GOOGLE_API_KEY also accepted (insight.py reads either).

# --- Anthropic (only if you have a key) -----------------------------------
# ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# --- OpenAI (only if you have a key) --------------------------------------
# OPENAI_API_KEY=YOUR_OPENAI_API_KEY
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- runtime flags --------------------------------------------------------
# Set LIFEOS_DEV=1 to allow CORS from any origin (otherwise file:// +
# localhost only). Leave at 0 unless you know what you're doing.
LIFEOS_DEV=0
